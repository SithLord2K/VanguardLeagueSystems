@inherits LayoutComponentBase

<MudThemeProvider Theme="_vanguardTheme" IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: -0.5px;">
            Vanguard League Systems
        </MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="Account/Login" Size="Size.Small">
            Sign In
        </MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <MudDrawerHeader Class="pb-0">
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">
                Menu
            </MudText>
        </MudDrawerHeader>
        <MudNavMenu Class="mt-2">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/leagues" Icon="@Icons.Material.Filled.EmojiEvents">Leagues</MudNavLink>
            <MudNavLink Href="/teams" Icon="@Icons.Material.Filled.Groups">Teams & Rosters</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-6 pt-2">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    // --- The Professional SaaS Theme ---
    private MudTheme _vanguardTheme = new MudTheme()
    {
        PaletteDark = new PaletteDark()
        {
            // Core UI Colors (Deep Slate/Navy instead of void black)
            Background = "#0f172a",      // Tailwind Slate 900
            AppbarBackground = "#1e293b",// Tailwind Slate 800
            DrawerBackground = "#0f172a",
            Surface = "#1e293b",         // Cards and panels

            // Brand & Accent Colors
            Primary = "#3b82f6",         // Professional Royal Blue
            Secondary = "#10b981",       // Success Green (great for active stats)
            Tertiary = "#f59e0b",        // Warning Orange

            // Text & Lines
            TextPrimary = "#f8fafc",
            TextSecondary = "#94a3b8",
            ActionDefault = "#cbd5e1",   // Soft grey for inactive icons
            Divider = "#334155"          // Subtle structural lines
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "6px", // Soft, approachable, modern corners
            AppbarHeight = "64px"
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Roboto", "Helvetica", "Arial", "sans-serif" },
                FontSize = "0.875rem",
                FontWeight = "400",
                LineHeight = "1.43",
                LetterSpacing = ".01071em"
            }
        }
    };
}